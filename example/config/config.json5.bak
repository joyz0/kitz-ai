{
  "meta": {
    "lastTouchedVersion": "1.0.0",
    "lastTouchedAt": "2026-03-04T07:41:01.399Z"
  },
  "env": {
    "vars": {
      "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
      "GEMINI_API_KEY": "${GEMINI_API_KEY}"
    },
    "OPENAI_API_KEY": "${OPENAI_API_KEY}"
  },
  "logging": {
    "level": "debug",
    "consoleLevel": "info",
    "consoleStyle": "pretty",
    "redactSensitive": "tools"
  },
  "session": {
    "scope": "per-sender",
    "dmScope": "main",
    "idleMinutes": 120,
    "reset": {
      "mode": "idle",
      "idleMinutes": 120
    }
  },
  "models": {
    "defaults": {
      "primary": "gpt-4o",
      "fallbacks": [
        "gpt-3.5-turbo"
      ]
    },
    "providers": {
      "openai": {
        "apiKey": "${OPENAI_API_KEY}"
      },
      "anthropic": {
        "apiKey": "${ANTHROPIC_API_KEY}"
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "gpt-4",
        "fallbacks": [
          "gpt-3.5-turbo"
        ]
      }
    },
    "list": [
      {
        "id": "main",
        "identity": {
          "name": "OpenClaw Assistant",
          "avatar": "https://example.com/avatar.png"
        }
      }
    ]
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "allowFrom": [
        "+1234567890",
        "+0987654321"
      ]
    },
    "telegram": {
      "enabled": false,
      "token": "${TELEGRAM_BOT_TOKEN}"
    }
  }
}
