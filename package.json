{
  "name": "kitz-ai",
  "version": "1.0.0",
  "description": "OpenClaw System Example",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev:config": "tsx src/config/index.ts",
    "example:config": "tsx example/config/index.ts",
    "debug:config": "tsx --inspect-brk example/config/index.ts",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "changelog:all": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0"
  },
  "dependencies": {
    "json5": "^2.2.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "conventional-changelog-cli": "^5.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.21.5"
    }
  }
}
